# Optional build-time API URL for the Next.js web app.
# If this is empty, users can paste their Worker API URL in the web UI.
NEXT_PUBLIC_API_BASE_URL=https://your-worker.your-subdomain.workers.dev/v1

# Optional deploy token for maintainers using non-interactive Wrangler deploys.
# End users do not need to put this in the browser.
CLOUDFLARE_API_TOKEN=

# Automatic analysis accumulation uses collected Shopping Insight trend data.
# No Naver Shopping Search API key is required for the local EXE accumulation workbook.
